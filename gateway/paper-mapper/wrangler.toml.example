name = "continuous-function-paper-mapper"
main = "worker.mjs"
compatibility_date = "2026-05-03"

[vars]
ALLOWED_ORIGINS = "https://continuousfunction.ai,https://www.continuousfunction.ai,http://127.0.0.1:3005"
OPENAI_MODEL = "gpt-5.4-mini"
RATE_LIMIT_PER_MINUTE = "20"
MAX_SOURCE_CHARS = "24000"
OPENAI_MAX_OUTPUT_TOKENS = "900"
