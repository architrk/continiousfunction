# Continuous Function local environment template
# Copy to .env.local for local development. Do not commit real secrets.

# Public site metadata. Browser-visible.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Clerk public/server identity values.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/me
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/me

# Neon/Postgres connection strings. Never expose through NEXT_PUBLIC_*.
# Use DATABASE_URL for pooled runtime traffic and DATABASE_URL_UNPOOLED for migrations/admin tasks.
# The current object-memory contract can generate/check Drizzle SQL without either value.
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Optional local-only account-memory contract check.
# Must be an app-owned users.id UUID, never a Clerk user_... id.
# Leave empty unless you have seeded a local/dev users row.
CF_DEV_ACCOUNT_MEMORY_OWNER_ID=
CF_DEV_ACCOUNT_MEMORY_ORGANIZATION_ID=

# Server-only AI provider key for future authenticated companion APIs.
OPENAI_API_KEY=

# Optional public gateway URLs while the existing stateless gateways remain in use.
NEXT_PUBLIC_CF_AI_GATEWAY_URL=
NEXT_PUBLIC_CF_PAPER_MAPPER_GATEWAY_URL=

# Optional static mirror build. Vercel production should leave this unset.
# CF_STATIC_EXPORT=1
