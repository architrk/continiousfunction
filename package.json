{
  "name": "ai-math-explainer",
  "version": "1.0.0",
  "private": true,
  "description": "Interactive explorations of the mathematical foundations of deep learning.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/architrk/continiousfunction-private.git"
  },
  "bugs": {
    "url": "https://github.com/architrk/continiousfunction-private/issues"
  },
  "homepage": "https://github.com/architrk/continiousfunction-private",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "security:check": "node scripts/security-check.js",
    "validate-content": "ts-node --transpileOnly scripts/validate-content.ts",
    "validate:object-memory": "ts-node --transpileOnly scripts/validate-object-memory-contract.ts",
    "verify:deployment-readiness": "node scripts/verify-deployment-readiness.js && npm run validate:object-memory",
    "verify:production": "node scripts/verify-production.js",
    "verify:ai-gateway": "node gateway/ai-companion/test.mjs",
    "verify:paper-gateway": "node gateway/paper-mapper/test.mjs",
    "audit:prod": "npm audit --omit=dev",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "generate-content": "ts-node --transpileOnly scripts/generate-content.ts",
    "generate-object-manifest": "ts-node --transpileOnly scripts/generate-content-object-manifest.ts",
    "generate-claim-evidence-review-queue": "ts-node --transpileOnly scripts/generate-claim-evidence-review-queue.ts",
    "video:studio": "remotion studio remotion/entry.ts",
    "video:render:tour": "remotion render remotion/entry.ts ContinuousFunctionTour artifacts/videos/continuous-function-tour.mp4",
    "build:static": "CF_STATIC_EXPORT=1 next build",
    "deploy:hostinger": "bash scripts/deploy-hostinger.sh",
    "prebuild": "npm run generate-content",
    "prebuild:static": "npm run generate-content",
    "predev": "npm run generate-content"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^15.5.15",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "d3": "^7.9.0",
    "d3-drag": "^3.0.0",
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "drizzle-orm": "^0.45.2",
    "gsap": "^3.15.0",
    "katex": "^0.16.45",
    "next": "^15.5.15",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rehype-katex": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "remark-math": "^6.0.0",
    "sanitize-html": "^2.17.3",
    "three": "^0.184.0"
  },
  "overrides": {
    "postcss": "8.5.14"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@next/bundle-analyzer": "^16.2.4",
    "@remotion/cli": "^4.0.457",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/d3": "^7.4.3",
    "@types/jest": "^30.0.0",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^20.19.39",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.2.0",
    "@types/sanitize-html": "^2.16.1",
    "@types/three": "^0.184.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.15",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.3.0",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-util": "^30.3.0",
    "ts-jest": "^29.4.9",
    "remotion": "^4.0.457",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "yaml": "^2.8.1"
  }
}
